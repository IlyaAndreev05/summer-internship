# ============================================================
# Режим запуска: console | vk | test | batch
# ============================================================
APP_MODE=console

# ============================================================
# LLM
# ============================================================
LLM_MODEL=qwen2.5:1.5b
LLM_BASE_URL=http://ollama:11434

EMBED_MODEL=nomic-embed-text

# ============================================================
# Qdrant (векторная БД)
# ============================================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=alina_docs

# ============================================================
# Postgres
# ============================================================
POSTGRES_URL=postgresql://alina:alina@postgres:5432/alina

# ============================================================
# VK бот (нужны ТОЛЬКО при APP_MODE=vk)
# ============================================================
# VK_TOKEN=ваш_токен_сообщества
# VK_GROUP_ID=123456789

# ============================================================
# Пути к данным
# ============================================================
DATA_DIR=data
PROJECTS_DIR=projects
TESTS_DIR=tests

# ============================================================
# Параметры индексации
# ============================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ============================================================
# Чат
# ============================================================
CHAT_VERBOSE=false
