# ── LLM ──────────────────────────────────────────────
# Provider: ollama (local) or openai (cloud)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:1.5b
# Base URL for OpenAI-compatible API (Ollama endpoint or OpenAI)
LLM_BASE_URL=http://localhost:11434/v1
# API key for OpenAI (leave empty when using Ollama)
LLM_API_KEY=

# ── Embeddings ────────────────────────────────────────
# Sentence-transformers model name
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Device: cpu or cuda
EMBED_DEVICE=cpu

# ── Database ──────────────────────────────────────────
# SQLite database path (async)
DATABASE_URL=sqlite+aiosqlite:///data/chat_history.db

# ── Vector Store ──────────────────────────────────────
# ChromaDB persistence directory
CHROMA_PERSIST_DIR=data/chroma
# ChromaDB collection name
CHROMA_COLLECTION=alina_docs

# ── Telegram Bot ──────────────────────────────────────
TELEGRAM_TOKEN=

# ── VK Bot ────────────────────────────────────────────
VK_TOKEN=
VK_GROUP_ID=

# ── Chat ──────────────────────────────────────────────
CHAT_MAX_MESSAGES=20

# ── Prompts ────────────────────────────────────────────
# Override the system prompt (inline string or @path/to/file.txt)
AGENT_SYSTEM_PROMPT=
# Extra context appended after system prompt: templates, greetings, rules
AGENT_EXTRA_CONTEXT=

# ── Chunking ───────────────────────────────────────────
CHUNKER_TYPE=paragraph
CHUNKER_SIZE=500
CHUNKER_OVERLAP=100

# ── Documents ─────────────────────────────────────────
DOCS_DIR=data/documents
